# =============================================================================
# AssistMe Portfolio - Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your values.
# Optional: create `.env.local` for machine-specific secrets; it overrides `.env`.
# NEVER commit `.env` or `.env.local` to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# AI API Configuration (Choose ONE provider)
# -----------------------------------------------------------------------------

# Option 1: OpenRouter (Recommended - supports multiple models)
# Server-side only. Used by FastAPI locally and Vercel serverless in production.
# Never prefix this with NEXT_PUBLIC and never place it in build-config.js.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=x-ai/grok-4.3

# Option 2: Google AI (Gemini) - for Google AI Challenge
# GOOGLE_API_KEY=your_google_ai_api_key_here

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Backend runtime port. Local frontend still runs on 4000 via npm scripts.
PORT=8001
VERCEL_ENV=development

# OpenRouter Site Metadata (for API tracking)
OPENROUTER_SITE_URL=https://mangeshraut.pro
OPENROUTER_SITE_TITLE=AssistMe AI Assistant

# -----------------------------------------------------------------------------
# Media Provider Configuration (Optional)
# -----------------------------------------------------------------------------
# The curated "Currently" catalog ships with local poster assets.
# TMDB / Google Books remain optional only for backend poster endpoints or future expansion.
# TMDB_API_KEY=your_tmdb_api_key_here
#
# Google Books improves backend book-cover lookup. If omitted, the backend falls back to
# Open Library where possible.
# GOOGLE_BOOKS_API_KEY=your_google_books_api_key_here

# Last.fm recent listening data is proxied through FastAPI so the secret key remains server-side.
# Use LASTFM_API_KEY for local FastAPI/Vercel serverless. Only set NEXT_PUBLIC_LASTFM_API_KEY
# if you deliberately want browser-side JSONP fallback with a public Last.fm key.
# LASTFM_API_KEY=your_lastfm_api_key_here
# LASTFM_USERNAME=mbr63
# NEXT_PUBLIC_LASTFM_API_KEY=

# -----------------------------------------------------------------------------
# Feature Flags (Optional)
# -----------------------------------------------------------------------------
# GitHub API authentication (optional, but recommended for proxy/rate limits)
# GITHUB_TOKEN=your_github_token_here
# GITHUB_PAT=your_github_token_here

# Optional shared analytics persistence for portfolio reach / homepage landings.
# When set on Vercel, the backend stores counters in Redis instead of local file fallback.
# Recommended for production if you want stable shared counts across deployments and instances.
# UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# Optional Google Analytics 4 Data API source for the detailed Portfolio Reach card.
# Add the service account email as a Viewer on the GA4 property before enabling this.
# Mangesh Raut Portfolio property (from analytics.google.com URL .../a394742220p537627192/...)
# GA4_ACCOUNT_ID=394742220
# GA4_PROPERTY_ID=537627192
# GOOGLE_ANALYTICS_SERVICE_ACCOUNT_JSON={"client_email":"analytics-reader@example.iam.gserviceaccount.com","private_key":"paste_escaped_service_account_private_key_here"}
# Or use split values instead of a JSON blob:
# GOOGLE_ANALYTICS_CLIENT_EMAIL=analytics-reader@your-project.iam.gserviceaccount.com
# GOOGLE_ANALYTICS_PRIVATE_KEY=paste_escaped_service_account_private_key_here

# ENABLE_VOICE_INPUT=true
# ENABLE_DEBUG_MODE=false
# RATE_LIMIT_REQUESTS=20
# RATE_LIMIT_WINDOW=60

# -----------------------------------------------------------------------------
# Integrations (Supabase + OAuth providers) — server-side only
# Put integration secrets in `.env.local` (or `.env`); sync to Vercel for production.
# See docs/integrations-roadmap.md and scripts/integrations/supabase-schema.sql
# -----------------------------------------------------------------------------
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_jwt
# SUPABASE_HEALTH_TABLE=health_vitals_daily
# INTEGRATION_SYNC_ADMIN_TOKEN=generate_a_long_random_token
# MONITOR_ADMIN_TOKEN=generate_a_long_random_token
# CRON_SECRET=generate_a_long_random_token
# INTEGRATION_ENCRYPTION_KEY=generate_a_32_byte_urlsafe_key
# SESSION_AUTH_SECRET=generate_a_long_random_token
# ENABLE_PUBLIC_API_DOCS=false
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=https://mangeshraut.pro/api/calendar/callback/google
# WHOOP_CLIENT_ID=
# WHOOP_CLIENT_SECRET=
# WHOOP_REDIRECT_URI=https://mangeshraut.pro/api/integrations/whoop/callback
# WITHINGS_CLIENT_ID=
# WITHINGS_CLIENT_SECRET=
# WITHINGS_REDIRECT_URI=https://mangeshraut.pro/api/integrations/withings/callback
