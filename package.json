{
  "name": "mangeshrautarchive",
  "type": "module",
  "license": "MIT",
  "main": "src/js/entry.js",
  "scripts": {
    "check-node": "node scripts/utils/check-node.mjs",
    "vendor:markdown": "node scripts/build/vendor-rich-markdown.mjs",
    "prebuild": "node scripts/utils/check-node.mjs && npm run vendor:markdown",
    "test": "node scripts/utils/check-node.mjs && vitest --run --passWithNoTests",
    "build": "node scripts/build/build.js",
    "build:css": "tailwindcss -i ./src/assets/css/tailwind-input.css -o ./src/assets/css/tailwind-output.css --minify",
    "dev": "node scripts/utils/check-node.mjs && node scripts/utils/dev-all.js",
    "dev:frontend": "API_TARGET=http://127.0.0.1:8001 node scripts/utils/local-server.js",
    "dev:backend": "node scripts/utils/dev-backend.js",
    "serve:dist": "node scripts/utils/serve-dist.js",
    "optimize-images": "node scripts/build/optimize-images.js",
    "lint": "node scripts/utils/check-node.mjs && eslint .",
    "lint:fix": "eslint . --fix",
    "lint:css": "node scripts/utils/check-node.mjs && stylelint \"src/assets/css/**/*.css\"",
    "lint:dead-code": "node scripts/utils/run-python-dead-code.js",
    "lint:python": "python -m flake8 api tests",
    "test:api": "python -m pytest -q tests/api",
    "typecheck": "node scripts/utils/check-node.mjs && node -e \"console.log('typecheck: vanilla ESM (no TypeScript / no Next.js runtime). IDE: jsconfig.json + globals.d.ts.');\"",
    "check": "node scripts/utils/check-node.mjs && npm run lint && npm run lint:css && npm run format:check && npm test",
    "security-check": "node scripts/deployment/security-check.js",
    "doctor": "node scripts/utils/repo-doctor.mjs",
    "doctor:strict": "node scripts/utils/repo-doctor.mjs --strict",
    "doctor:full": "node scripts/deployment/verify-env-parity.mjs",
    "doctor:stack": "node scripts/utils/repo-doctor.mjs",
    "qa:browser:ci": "node scripts/qa/promotion-fps-audit.mjs",
    "qa:lighthouse:ci": "node scripts/deployment/lighthouse-gate.js --url=https://mangeshraut712.github.io/mangeshrautarchive/ --form-factor=desktop --min-performance=90 --min-accessibility=90 --min-best-practices=90 --min-seo=90 --max-attempts=1 && node scripts/deployment/lighthouse-gate.js --url=https://mangeshraut712.github.io/mangeshrautarchive/ --form-factor=mobile --min-performance=85 --min-accessibility=90 --min-best-practices=90 --min-seo=90 --max-attempts=1",
    "qa:lighthouse:vercel": "node scripts/deployment/lighthouse-gate.js --url=https://mangeshraut.pro/ --form-factor=desktop --min-performance=55 --min-accessibility=90 --min-best-practices=90 --min-seo=90 --max-attempts=2 && node scripts/deployment/lighthouse-gate.js --url=https://mangeshraut.pro/ --form-factor=mobile --min-performance=55 --min-accessibility=90 --min-best-practices=90 --min-seo=90 --max-attempts=2",
    "clean": "node scripts/build/clean.js",
    "open": "open src/index.html",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "npx playwright test --project=\"Desktop Chrome\"",
    "test:e2e:chrome": "npx playwright test --project=\"Desktop Chrome\"",
    "test:e2e:all": "npx playwright test",
    "qa:prod-ready": "npm run security-check && npm run lint && npm run lint:css && npm run format:check && npm test && npm run test:api && npx playwright test --project=\"Desktop Chrome\" && npm run qa:lighthouse:ci",
    "qa:lighthouse:desktop": "node scripts/deployment/lighthouse-gate.js --url=http://127.0.0.1:4000/ --form-factor=desktop --min-performance=90 --min-accessibility=90 --min-best-practices=90 --min-seo=90",
    "qa:lighthouse:mobile": "node scripts/deployment/lighthouse-gate.js --url=http://127.0.0.1:4000/ --form-factor=mobile --min-performance=85 --min-accessibility=90 --min-best-practices=90 --min-seo=90",
    "qa:lighthouse:systems": "node scripts/deployment/lighthouse-gate.js --url=http://127.0.0.1:4000/systems --full-load --form-factor=desktop --min-performance=75 --min-accessibility=95 --min-best-practices=95 --min-seo=90 --max-attempts=2 --output-dir=artifacts/lighthouse/systems",
    "qa:lighthouse:monitor": "node scripts/deployment/lighthouse-gate.js --url=http://127.0.0.1:4000/monitor --full-load --form-factor=desktop --min-performance=65 --min-accessibility=95 --min-best-practices=95 --min-seo=90 --max-attempts=2 --output-dir=artifacts/lighthouse/monitor",
    "qa:lighthouse:travel": "node scripts/deployment/lighthouse-gate.js --url=http://127.0.0.1:4000/travel --full-load --form-factor=desktop --min-performance=75 --min-accessibility=95 --min-best-practices=95 --min-seo=90 --max-attempts=2 --output-dir=artifacts/lighthouse/travel",
    "qa:lighthouse:uses": "node scripts/deployment/lighthouse-gate.js --url=http://127.0.0.1:4000/uses --full-load --form-factor=desktop --min-performance=70 --min-accessibility=95 --min-best-practices=95 --min-seo=90 --max-attempts=2 --output-dir=artifacts/lighthouse/uses",
    "qa:lighthouse:subpages": "npm run qa:lighthouse:systems && npm run qa:lighthouse:monitor && npm run qa:lighthouse:travel && npm run qa:lighthouse:uses",
    "verify:deploy-sync": "node scripts/deployment/verify-deployment-sync.js --remote --parity",
    "qa:postdeploy": "node scripts/deployment/verify-deployment-sync.js --remote --parity --retries=12 --wait=20",
    "qa:surfaces": "node scripts/deployment/verify-deployment-sync.js --remote --parity --retries=6 --wait=15",
    "foglamp:publish": "node scripts/integrations/publish-foglamp-scan.mjs"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/cli": "^4.3.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.5",
    "express": "^5.2.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "sharp": "^0.35.2",
    "start-server-and-test": "^3.0.11",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.0.9",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@ogtirth/liquid-glass-oss": "^0.1.0",
    "@vercel/analytics": "^2.0.1",
    "html-to-image": "^1.11.13",
    "isomorphic-dompurify": "^3.17.0",
    "katex": "^0.18.1",
    "marked": "^18.0.6",
    "marked-footnote": "^1.2.2",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=22 <27"
  }
}
