rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isShortString(value, maxLength) {
      return value is string && value.size() > 0 && value.size() <= maxLength;
    }

    function isOptionalString(value, maxLength) {
      return value is string && value.size() <= maxLength;
    }

    function isEmail(value) {
      return value is string && value.size() >= 3 && value.size() <= 254 && value.matches('.+@.+\\..+');
    }

    function validContactMessage() {
      return request.resource.data.keys().hasOnly([
          'name',
          'email',
          'subject',
          'message',
          'timestamp',
          'userAgent',
          'submittedFrom'
        ])
        && request.resource.data.keys().hasAll(['name', 'email', 'subject', 'message', 'timestamp'])
        && isShortString(request.resource.data.name, 120)
        && isEmail(request.resource.data.email)
        && isShortString(request.resource.data.subject, 180)
        && isShortString(request.resource.data.message, 4000)
        && request.resource.data.timestamp is timestamp
        && isOptionalString(request.resource.data.userAgent, 512)
        && isOptionalString(request.resource.data.submittedFrom, 512);
    }

    function validNewsletterSubscriber() {
      return request.resource.data.keys().hasOnly([
          'email',
          'subscribedAt',
          'source',
          'userAgent',
          'submittedFrom'
        ])
        && request.resource.data.keys().hasAll(['email', 'subscribedAt', 'source'])
        && isEmail(request.resource.data.email)
        && request.resource.data.subscribedAt is timestamp
        && request.resource.data.source == 'blog_newsletter'
        && isOptionalString(request.resource.data.userAgent, 512)
        && isOptionalString(request.resource.data.submittedFrom, 512);
    }

    function validAnalyticsMetric() {
      return request.resource.data.keys().hasOnly(['total_views'])
        && request.resource.data.total_views is int
        && request.resource.data.total_views >= 0;
    }

    match /messages/{document} {
      allow create: if validContactMessage();
      allow read: if false;
    }

    match /newsletter_subscribers/{document} {
      allow create: if validNewsletterSubscriber();
      allow read, update, delete: if false;
    }

    match /analytics/{document} {
      allow get: if document == 'metrics';
      allow list: if false;
      allow create: if document == 'metrics'
        && validAnalyticsMetric()
        && request.resource.data.total_views <= 1;
      allow update: if document == 'metrics'
        && validAnalyticsMetric()
        && request.resource.data.total_views == resource.data.total_views + 1;
      allow delete: if false;
    }
  }
}
